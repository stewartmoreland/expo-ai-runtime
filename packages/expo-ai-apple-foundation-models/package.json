{
  "name": "@stewmore/expo-ai-apple-foundation-models",
  "version": "0.1.0",
  "description": "Apple Foundation Models (on-device, iOS 26+) provider for the Expo AI Runtime.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build",
    "src",
    "ios",
    "expo-module.config.json",
    "ExpoAIApple.podspec"
  ],
  "sideEffects": ["./build/index.js", "./src/index.ts"],
  "keywords": ["expo", "react-native", "ai", "apple", "foundation-models", "on-device"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json"
  },
  "dependencies": {
    "@stewmore/expo-ai-core": "^0.1.0"
  },
  "peerDependencies": {
    "expo": "*",
    "react": "*",
    "react-native": "*"
  },
  "devDependencies": {
    "typescript": "~6.0.3"
  }
}
