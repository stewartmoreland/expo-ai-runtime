{
  "name": "@stewmore/expo-ai-core",
  "version": "0.7.2",
  "description": "Mobile-native AI runtime core: unified ExpoAI API, provider router, capability detection, sessions, structured output, privacy metadata, and normalized errors.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stewartmoreland/expo-ai-runtime.git",
    "directory": "packages/expo-ai-core"
  },
  "homepage": "https://github.com/stewartmoreland/expo-ai-runtime/tree/main/packages/expo-ai-core#readme",
  "bugs": "https://github.com/stewartmoreland/expo-ai-runtime/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    },
    "./testing": {
      "types": "./build/testing.d.ts",
      "default": "./build/testing.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "expo",
    "react-native",
    "ai",
    "on-device",
    "foundation-models",
    "gemini-nano"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
