{
  "name": "@stewmore/expo-ai-cloud",
  "version": "0.7.1",
  "description": "Cloud fallback adapter for the Expo AI Runtime. POSTs to a configurable backend (OpenAI / Anthropic / Gemini / Bedrock / custom) with streaming via expo/fetch.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stewartmoreland/expo-ai-runtime.git",
    "directory": "packages/expo-ai-cloud"
  },
  "homepage": "https://github.com/stewartmoreland/expo-ai-runtime/tree/main/packages/expo-ai-cloud#readme",
  "bugs": "https://github.com/stewartmoreland/expo-ai-runtime/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "sideEffects": false,
  "keywords": [
    "expo",
    "react-native",
    "ai",
    "cloud",
    "fallback"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@stewmore/expo-ai-core": "^0.7.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.9",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
