{
  "name": "@stewmore/expo-ai-cloud",
  "version": "0.1.1",
  "description": "Cloud fallback adapter for the Expo AI Runtime. POSTs to a configurable backend (OpenAI / Anthropic / Gemini / Bedrock / custom) with streaming via expo/fetch.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": ["build", "src"],
  "sideEffects": false,
  "keywords": ["expo", "react-native", "ai", "cloud", "fallback"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@stewmore/expo-ai-core": "^0.1.0"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
