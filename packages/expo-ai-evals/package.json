{
  "name": "@stewmore/expo-ai-evals",
  "version": "0.1.0",
  "description": "Node-first evaluation harness for the Expo AI Runtime: provider comparison, schema validity, latency, fallback frequency, and privacy boundaries.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": ["build", "src", "fixtures"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "eval": "tsx src/cli.ts"
  },
  "dependencies": {
    "@stewmore/expo-ai-cloud": "^0.1.0",
    "@stewmore/expo-ai-core": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.8"
  }
}
