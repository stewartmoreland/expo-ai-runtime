{
  "name": "@stewmore/expo-ai-evals",
  "version": "0.7.2",
  "description": "Node-first evaluation harness for the Expo AI Runtime: provider comparison, schema validity, latency, fallback frequency, and privacy boundaries.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stewartmoreland/expo-ai-runtime.git",
    "directory": "packages/expo-ai-evals"
  },
  "homepage": "https://github.com/stewartmoreland/expo-ai-runtime/tree/main/packages/expo-ai-evals#readme",
  "bugs": "https://github.com/stewartmoreland/expo-ai-runtime/issues",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "./build/index.js",
  "types": "./build/index.d.ts",
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "default": "./build/index.js"
    }
  },
  "files": [
    "build",
    "src",
    "fixtures"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "clean": "rm -rf build",
    "typecheck": "tsc --noEmit -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "eval": "tsx src/cli.ts"
  },
  "dependencies": {
    "@stewmore/expo-ai-cloud": "^0.7.2",
    "@stewmore/expo-ai-core": "^0.7.2"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "tsx": "^4.19.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
