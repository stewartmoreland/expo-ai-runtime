{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireBranch": "main",
    "push": false
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": false,
  "plugins": {
    "@release-it-plugins/workspaces": {
      "workspaces": ["packages/*"],
      "publish": true,
      "skipChecks": true
    },
    "@release-it/conventional-changelog": {
      "preset": "conventionalcommits",
      "infile": "CHANGELOG.md"
    }
  }
}
