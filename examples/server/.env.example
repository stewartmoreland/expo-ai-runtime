# Reference server configuration. Copy to .env and fill in to proxy a real model.
# Leave everything blank to run in mock mode (the default).

PORT=8787

# OpenAI-compatible (also OpenRouter / Ollama / LM Studio via OPENAI_BASE_URL)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-latest

# Force mock mode even if keys are present
# EXPO_AI_FORCE_MOCK=1
