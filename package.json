{
  "name": "expo-ai-runtime",
  "version": "0.1.1",
  "private": true,
  "description": "A mobile-native AI runtime for Expo and React Native: one TypeScript API over Apple Foundation Models, Android Gemini Nano (ML Kit GenAI / AICore), and an explicit cloud fallback.",
  "license": "MIT",
  "author": "Stewart Moreland <stewart.moreland@gmail.com>",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build -w @stewmore/expo-ai-core && npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "clean": "npm run clean --workspaces --if-present",
    "eval": "npm run eval --workspace @stewmore/expo-ai-evals",
    "server": "npm run dev --workspace @stewmore/expo-ai-server",
    "release": "release-it"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@release-it-plugins/workspaces": "^6.0.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.6.0",
    "prettier": "^3.8.4",
    "release-it": "^19.2.4",
    "typescript-eslint": "^8.61.1"
  },
  "engines": {
    "node": ">=20"
  }
}
